# BetterCMS delivery reads — a content:read key is enough for the site.
# On BetterCMS hosting these are injected automatically when you create the site
# from the Marketing Starter template; set them here only for local development.
BETTERCMS_API_URL=https://api.bettercms.ai
BETTERCMS_WORKSPACE=your-workspace-slug
BETTERCMS_API_KEY=bcms_xxx

# Integration test ONLY (test/chain.integration.test.ts) — needs content:manage to
# provision + tear down its own fixtures. Leave unset to skip the test.
BETTERCMS_MGMT_KEY=bcms_xxx
